# ---- Devin (v3 service-user key, cog_ prefix) ----
DEVIN_API_KEY=
# Settings > Service Users in the Devin dashboard. Required for live mode.
DEVIN_ORG_ID=
DEVIN_API_BASE=https://api.devin.ai/v3
# auto | live | mock  -- "auto" uses live when key+org are set, else mock
DEVIN_MODE=auto
DEVIN_MAX_ACU=10

# ---- GitHub ----
GITHUB_TOKEN=
# The ONLY repo this system may write to. Guardrail, not a default.
GITHUB_REPO=raymondtangsc/superset
GITHUB_WEBHOOK_SECRET=

# ---- Behaviour ----
TRIGGER_LABEL=devin-unblock
# Scheduled sweep interval. The sweep is the source of truth for detection;
# webhooks are the low-latency path on top. 0 = webhook-only.
POLL_INTERVAL_SECONDS=600
MAX_DISPATCHES_PER_EVENT=3
DB_PATH=data/unblocker.db
# Only touch PRs quiet for at least this many days (0 = off; 0.0007 ~= one
# minute, handy for demos). Protects work in progress from being rebased under
# its author; the manual label overrides.
MIN_QUIET_DAYS=3
